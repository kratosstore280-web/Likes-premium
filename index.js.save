const { 
    default: makeWASocket, 
    useMultiFileAuthState, 
    DisconnectReason, 
    fetchLatestBaileysVersion 
} = require('@whiskeysockets/baileys');
const { Boom } = require('@hapi/boom');
const P = require('pino');
const fs = require('fs');
const qrcode = require('qrcode-terminal');
const fetch = (...args) => import('node-fetch').then(({default: fetch}) => fetch(...args));

async function startBot() {
    const { state, saveCreds } = await useMultiFileAuthState('auth_info');
    const { version } = await fetchLatestBaileysVersion();

    const sock = makeWASocket({
        auth: state,
        version,
        logger: P({ level: 'silent' }),
        printQRInTerminal: false
    });

    sock.ev.on('creds.update', saveCreds);

    sock.ev.on('connection.update', (update) => {
        const { connection, qr } = update;
        if (qr) {
            console.log('📌 ESCANEIE O QR CODE PARA CONECTAR:');
            qrcode.generate(qr, { small: true });
        }
        if (connection === 'open') console.log('✅ KRATOS BOT ONLINE - VIP ATUALIZADO!');
        if (connection === 'close') startBot();
    });

    const vipsFile = './vips.json';
    if (!fs.existsSync(vipsFile)) fs.writeFileSync(vipsFile, JSON.stringify([]));
    const getVips = () => JSON.parse(fs.readFileSync(vipsFile, 'utf-8'));
    const salvarVips = (data) => fs.writeFileSync(vipsFile, JSON.stringify(data, null, 2));

    sock.ev.on('messages.upsert', async ({ messages }) => {
        try {
            const msg = messages[0];
            if (!msg.message || msg.key.fromMe) return;

            const remoteJid = msg.key.remoteJid; 
            const participant = msg.key.participant; 
            const sender = remoteJid.endsWith('@g.us') ? participant : remoteJid; 
            
            // Extrai apenas os números do remetente para comparação limpa
            const senderNumber = sender.replace(/[^0-9]/g, '');

            const body = (msg.message.conversation || msg.message.extendedTextMessage?.text || "").trim();
            const prefix = "!"; 
            if (!body.startsWith(prefix)) return;

            const command = body.slice(prefix.length).trim().split(/ +/).shift().toLowerCase();
            const q = body.slice(prefix.length + command.length).trim();

            // Configuração do Dono (Bruno)
            const meuIdDono = "25701671538894";
            const isOwner = senderNumber.includes(meuIdDono);

            const reply = (text) => sock.sendMessage(remoteJid, { text: text }, { quoted: msg });
            const imagePath = './kratos.jpg';

            switch (command) {
                case 'addvip': {
                    if (!isOwner) return reply("❌ Apenas o dono Bruno pode usar este comando.");
                    const args = q.split('|');
                    if (args.length < 2) return reply("📌 Use: !addvip numero|dias\nEx: !addvip 5551912345678|30");
                    
                    const pureNumber = args[0].replace(/[^0-9]/g, '');
                    const targetJid = pureNumber + '@s.whatsapp.net';
                    const expira = Date.now() + (parseInt(args[1]) * 24 * 60 * 60 * 1000);
                    
                    let vips = getVips();
                    // Remove se já existia para atualizar o prazo
                    vips = vips.filter(v => v.id.replace(/[^0-9]/g, '') !== pureNumber);
                    
                    vips.push({ id: targetJid, expiracao: expira });
                    salvarVips(vips);
                    
                    reply(`💎 *VIP ATIVADO COM SUCESSO!*\n\n👤 Usuário: @${pureNumber}\n📅 Prazo: ${args[1]} dias`, { mentions: [targetJid] });
                    break;
                }

                case 'likes':
                case 'likesff': {
                    const vips = getVips();
                    // Busca o usuário comparando apenas os números para evitar erros de formatação
                    const userVip = vips.find(v => v.id.replace(/[^0-9]/g, '') === senderNumber);
                    
                    // Bloqueio: Se não for dono E (não for VIP ou VIP expirado)
                    if (!isOwner) {
                        if (!userVip) {
                            return reply("❌ Você não possui acesso VIP. Entre em contato com @Bruno para adquirir.");
                        }
                        if (Date.now() > userVip.expiracao) {
                            return reply("⚠️ Seu acesso VIP expirou! Renove com @Bruno.");
                        }
                    }

                    if (!q) return reply(`📌 Use: !likesff [UID]`);
                    reply("⏳ Processando seu pedido, aguarde...");

                    const key = 'LIKESFF-Panel-key-bielmotam';
                    const apiUrl = `https://likesff.online/api/LIKE?uid=${encodeURIComponent(q)}&cache=true&key=${key}`;

                    const res = await fetch(apiUrl, { headers: { 'User-Agent': 'Mozilla/5.0', 'x-panel-token': 'lff-internal' } });
                    const json = await res.json().catch(() => null);

                    if (!json || json.status === "failed") {
                        const textoErro = `❌ *LIKES NÃO ENVIADOS*\n\n👤 *Nick:* ${json?.nickname || 'Desconhecido'}\n🆔 *UID:* ${q}\n🌎 *Região:* BR\n\n❤️ *Likes atuais:* ${json?.likes_before || '---'}\n📉 *Falha no envio:* 220\n\n⚠️ *Motivo:* Limite diário atingido ou ID já recebeu likes hoje.\n\n💡 *Use:* !infolikes`;
                        
                        if (fs.existsSync(imagePath)) {
                            return await sock.sendMessage(remoteJid, { image: { url: imagePath }, caption: textoErro }, { quoted: msg });
                        }
                        return reply(textoErro);
                    }

                    const ganhos = parseInt(json.likes_end) - parseInt(json.likes_before);
                    const textoSucesso = `✅ *LIKES ENVIADOS COM SUCESSO!*\n\n👤 *Nick:* ${json.nickname}\n🆔 *UID:* ${q}\n🌎 *Região:* BR\n\n❤️ *Antes:* ${json.likes_before}\n💖 *Depois:* ${json.likes_end}\n📈 *Ganhos:* ${ganhos}\n\n⚔️ *Kratos Bot V1*\n👤 *Dono:* Bruno\n\n💡 *Use:* !infolikes`;

                    if (fs.existsSync(imagePath)) {
                        await sock.sendMessage(remoteJid, { image: { url: imagePath }, caption: textoSucesso }, { quoted: msg });
                    } else {
                        reply(textoSucesso);
                    }
                    break;
                }

                case 'meuvip': {
                    if (isOwner) return reply("💎 Bruno, você tem acesso Vitalício como Administrador.");
                    const vips = getVips();
                    const user = vips.find(v => v.id.replace(/[^0-9]/g, '') === senderNumber);
                    
                    if (!user) return reply("❌ Você não possui um plano VIP ativo.");
                    
                    const resta = user.expiracao - Date.now();
                    if (resta < 0) return reply("⚠️ Seu VIP expirou.");
                    
                    const dias = Math.floor(resta / (1000 * 60 * 60 * 24));
                    reply(`💎 Seu VIP resta ${dias} dias de acesso.`);
                    break;
                }

                case 'infolikes':
                    reply("📖 *COMO FUNCIONA O BOT:*\n\n1. O limite é de 1 envio a cada 24 horas por UID.\n2. Não precisa da senha da conta.\n3. O envio é instantâneo.\n\nContrate o VIP para acesso ilimitado!");
                    break;
            }
        } catch (e) { console.error("Erro no processamento:", e); }
    });
}
startBot();
